                            Content="Retry"
                            Background="{DynamicResource Brush.Transparent}"
                            Foreground="{DynamicResource Brush.State.Warning}"
                            BorderBrush="{DynamicResource Brush.Transparent}"
                            FontSize="{DynamicResource Musait.Font.Body}"
                            Padding="6,0"
                            Cursor="Hand"
                            Click="InlineBannerAction_Click"/>
                    <TextBlock x:Name="InlineBannerText"
                               Text="Gemini sign-in required."
                               Foreground="{DynamicResource Brush.State.Warning}"
                               FontSize="{DynamicResource Musait.Font.Body}"
