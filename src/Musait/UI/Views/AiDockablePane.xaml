                                            <StackPanel x:Name="FamilyReferenceEmptyHint"
                                                        VerticalAlignment="Center"
                                                        Margin="12">
                                                <TextBlock Text="Reference ready for AI Studio"
                                                           Foreground="{DynamicResource Brush.Text.Primary}"
                                                           FontSize="{DynamicResource Musait.Font.Section}"
                                                           FontWeight="SemiBold"
                                                           TextAlignment="Center"/>
                                                <TextBlock Text="Drag and drop or click to browse"
                                                           Foreground="{DynamicResource Brush.Text.Secondary}"
                                                           FontSize="{DynamicResource Musait.Font.Body}"
                                                           FontWeight="SemiBold"
                                                           TextAlignment="Center"
                                                           Margin="0,7,0,0"/>
                                                <TextBlock Text="Use an image reference or a Family JSON file to continue the pipeline."
                                                           Foreground="{DynamicResource Brush.Text.Tertiary}"
                                                           FontSize="{DynamicResource Musait.Font.Description}"
                                                           TextWrapping="Wrap"
                                                           TextAlignment="Center"
                                                           Margin="0,5,0,0"/>
