                        <Border BorderBrush="{DynamicResource Brush.Border.Primary}" BorderThickness="0,1,0,0"/>
                        <StackPanel Margin="9">
                            <TextBlock Text="CONTEXT &amp; PRIVACY" Foreground="{DynamicResource Brush.Text.Tertiary}" FontSize="{DynamicResource Musait.Font.Description}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <CheckBox x:Name="SettingsContextCheck" Style="{DynamicResource MusaitCheckBoxStyle}" Content="Include Revit context"/>
                            <TextBlock Text="View name, scale, level, project" Foreground="{DynamicResource Brush.Text.Tertiary}" FontSize="{DynamicResource Musait.Font.Description}" Margin="22,2,0,0"/>
                        </StackPanel>

                        <Border BorderBrush="{DynamicResource Brush.Border.Primary}" BorderThickness="0,1,0,0"/>
                        <StackPanel Margin="9">
                            <TextBlock Text="APPEARANCE" Foreground="{DynamicResource Brush.Text.Tertiary}" FontSize="{DynamicResource Musait.Font.Description}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <DockPanel LastChildFill="False">
                                <TextBlock Text="Theme" Foreground="{DynamicResource Brush.Text.Secondary}" FontSize="{DynamicResource Musait.Font.Body}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                                <ComboBox x:Name="SettingsThemeCombo" Width="142" Style="{DynamicResource MusaitComboBoxStyle}" DockPanel.Dock="Right">
                                    <ComboBoxItem Content="Dark"/>
                                    <ComboBoxItem Content="Light"/>
                                </ComboBox>
                            </DockPanel>
                        </StackPanel>

                        <Border BorderBrush="{DynamicResource Brush.Border.Primary}" BorderThickness="0,1,0,0"/>
                        <StackPanel Margin="9">
                            <TextBlock Text="ARCHIVES" Foreground="{DynamicResource Brush.Text.Tertiary}" FontSize="{DynamicResource Musait.Font.Description}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <CheckBox x:Name="SettingsArchiveCheck" Style="{DynamicResource MusaitCheckBoxStyle}" Content="Save captures to folder"/>
                            <Border Background="{DynamicResource Brush.Background.Tertiary}" BorderBrush="{DynamicResource Brush.Border.Secondary}" BorderThickness="1" CornerRadius="{DynamicResource Musait.Radius.Control}" Padding="8,5" Margin="0,7,0,0">
                                <TextBlock Text="%Pictures%\Musait\" Foreground="{DynamicResource Brush.Text.Tertiary}" FontSize="{DynamicResource Musait.Font.Description}" FontFamily="Consolas" TextTrimming="CharacterEllipsis"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Background="{DynamicResource Brush.Background.Secondary}"
                        BorderBrush="{DynamicResource Brush.Border.Primary}"
                        BorderThickness="0,1,0,0"
                        Padding="9">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="Reset defaults"
                                Background="{DynamicResource Brush.Transparent}"
                                Foreground="{DynamicResource Brush.Text.Tertiary}"
                                BorderBrush="{DynamicResource Brush.Transparent}"
                                HorizontalAlignment="Left"
                                FontSize="{DynamicResource Musait.Font.Body}"
                                Cursor="Hand"
                                Click="ResetSettingsBtn_Click"/>
                        <Button Grid.Column="1"
                                Content="Cancel"
                                Style="{DynamicResource MusaitSecondaryButtonStyle}"
                                Click="CancelSettingsBtn_Click"/>
                        <Button Grid.Column="2"
                                Content="Save"
                                Style="{DynamicResource MusaitPrimaryButtonStyle}"
                                Height="28"
                                MinWidth="58"
                                Margin="6,0,0,0"
                                Click="SaveSettingsBtn_Click"/>
                    </Grid>
                </Border>
            </Grid>

            <Grid x:Name="AboutPanel"
                  Grid.RowSpan="2"
                  Visibility="Collapsed"
                  Background="{DynamicResource Brush.Background.Primary}"
                  Panel.ZIndex="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="34"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Background="{DynamicResource Brush.Background.Secondary}"
                        BorderBrush="{DynamicResource Brush.Border.Secondary}"
                        BorderThickness="0,0,0,1"
                        Padding="9,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Style="{DynamicResource MusaitIconButtonStyle}"
                                ToolTip="Back"
                                AutomationProperties.Name="Back"
                                Click="CloseAboutBtn_Click">
                            <TextBlock Text="‹" Foreground="{DynamicResource Brush.Text.Tertiary}" FontSize="18"/>
                        </Button>
                        <TextBlock Grid.Column="1"
                                   Text="About"
                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                   FontSize="{DynamicResource Musait.Font.Section}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="7,0,0,0"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="9">
                        <Border Background="{DynamicResource Brush.Background.Secondary}"
                                BorderBrush="{DynamicResource Brush.Border.Secondary}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource Musait.Radius.Panel}"
                                Padding="10">
                            <StackPanel>
                                <TextBlock x:Name="AboutTitleText"
                                           Text="Musait"
                                           Foreground="{DynamicResource Brush.Text.Primary}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>
                                <TextBlock x:Name="AboutBylineText"
                                           Text="by Mashyo"
                                           Foreground="{DynamicResource Brush.Text.Secondary}"
                                           FontSize="{DynamicResource Musait.Font.Body}"
                                           Margin="0,3,0,0"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="Musait EULA · github.com/mashyo/musait"
                                           Foreground="{DynamicResource Brush.Text.Tertiary}"
                                           FontSize="{DynamicResource Musait.Font.Description}"
                                           Margin="0,3,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource Brush.Background.Primary}"
                                BorderBrush="{DynamicResource Brush.Border.Primary}"
                                BorderThickness="0,1,0,0"
                                Margin="0,12,0,0"
                                Padding="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="UPDATES"
                                           Foreground="{DynamicResource Brush.Text.Tertiary}"
                                           FontSize="{DynamicResource Musait.Font.Description}"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,7"/>
                                <TextBlock x:Name="UpdateStatusText"
                                           Text="Current version is installed."
                                           Foreground="{DynamicResource Brush.Text.Secondary}"
                                           FontSize="{DynamicResource Musait.Font.Body}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8"/>
                                <UniformGrid Columns="2">
                                    <Button x:Name="CheckUpdatesButton"
                                            Content="Check updates"
                                            Style="{DynamicResource MusaitSecondaryButtonStyle}"
                                            Margin="0,0,4,0"
                                            Click="CheckUpdatesBtn_Click"/>
                                    <Button x:Name="DownloadUpdateButton"
                                            Content="Download"
                                            Style="{DynamicResource MusaitPrimaryButtonStyle}"
                                            Margin="4,0,0,0"
                                            Visibility="Collapsed"
                                            Click="DownloadUpdateBtn_Click"/>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource Brush.Background.Primary}"
                                BorderBrush="{DynamicResource Brush.Border.Primary}"
                                BorderThickness="0,1,0,0"
                                Margin="0,13,0,0"
                                Padding="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="SUPPORT"
                                           Foreground="{DynamicResource Brush.Text.Tertiary}"
                                           FontSize="{DynamicResource Musait.Font.Description}"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,7"/>
                                <TextBlock Text="Renderings stay free. Supporter features help keep Musait current as Revit, WebView2, and Gemini change."
                                           Foreground="{DynamicResource Brush.Text.Secondary}"
                                           FontSize="{DynamicResource Musait.Font.Description}"
                                           TextWrapping="Wrap"
                                           LineHeight="15"
                                           Margin="0,0,0,10"/>
                                <Button Content="Support development"
                                        Style="{DynamicResource MusaitPrimaryButtonStyle}"
                                        HorizontalAlignment="Stretch"
                                        Height="30"
                                        Click="SupportDevelopmentBtn_Click"/>
                                <UniformGrid Columns="2" Margin="0,7,0,0">
                                    <Button Content="GitHub"
                                            Style="{DynamicResource MusaitSecondaryButtonStyle}"
                                            Margin="0,0,4,0"
                                            Click="RepositoryBtn_Click"/>
                                    <Button Content="Releases"
                                            Style="{DynamicResource MusaitSecondaryButtonStyle}"
                                            Margin="4,0,0,0"
                                            Click="ReleasesBtn_Click"/>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Credits: Newtonsoft.Json, Nice3point.Revit.Api, Microsoft WebView2."
                                   Foreground="{DynamicResource Brush.Text.Tertiary}"
                                   FontSize="9"
                                   TextWrapping="Wrap"
                                   Margin="0,13,0,0"/>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Background="{DynamicResource Brush.Background.Secondary}"
                        BorderBrush="{DynamicResource Brush.Border.Primary}"
                        BorderThickness="0,1,0,0"
                        Padding="9">
                    <Button Content="Close"
                            Style="{DynamicResource MusaitSecondaryButtonStyle}"
                            HorizontalAlignment="Right"
                            Click="CloseAboutBtn_Click"/>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>

