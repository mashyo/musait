                                 BorderThickness="1"
                                 CornerRadius="{DynamicResource Musait.Radius.Panel}"
                                Padding="9">
                             <TextBlock x:Name="BuildPipelineDescription"
                                       Text="Attach a reference image or JSON. AI Studio produces a strict Family JSON definition for local preview."
