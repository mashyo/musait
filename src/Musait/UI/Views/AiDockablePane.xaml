                                        <Button Content="Paste"
                                                Style="{DynamicResource FamilyAcquireSecondaryButtonStyle}"
                                                ToolTip="Import copied JSON from the clipboard"
                                                Click="FamilyPasteJsonButton_Click"/>
                                        <Button Grid.Column="2"
                                                Content="Manual"
                                                Style="{DynamicResource FamilyAcquireSecondaryButtonStyle}"
                                                ToolTip="Open the manual JSON paste view"
                                                Click="FamilyFromJsonButton_Click"/>
                                    </Grid>
                                </StackPanel>

                                <StackPanel x:Name="FamilyPreviewView" Visibility="Collapsed">
                                    <Grid x:Name="FamilyPreviewHeader" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Content="&lt;"
                                                Style="{DynamicResource MusaitIconButtonStyle}"
                                                Width="24"
                                                Height="24"
                                                Margin="0,0,7,0"
                                                Click="FamilyBackToJsonButton_Click"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="Preview"
                                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                                   FontSize="{DynamicResource Musait.Font.Section}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
