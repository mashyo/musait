                                       FontSize="{DynamicResource Musait.Font.Body}"
                                       TextWrapping="Wrap"
                                       LineHeight="17"/>
                        </Border>

                        <Grid x:Name="FamilyPipelinePanel"
                              Visibility="Collapsed"
                              Margin="0,9,0,0">
                            <StackPanel>
                                <StackPanel x:Name="FamilySourceView">
                                    <TextBlock Text="Family"
