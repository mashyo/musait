                                               FontSize="13"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="Build a Revit family from an image, or import JSON directly."
                                               Foreground="{DynamicResource Brush.Text.Tertiary}"
                                               FontSize="{DynamicResource Musait.Font.Description}"
                                               TextWrapping="Wrap"
                                               Margin="0,2,0,12"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="FamilyFromImageButton"
                                                Grid.Column="0"
                                                MinHeight="86"
                                                Style="{DynamicResource ComposerPresetCardStyle}"
                                                ToolTip="Attach or capture a reference image for AI Studio"
                                                Click="FamilyFromImageButton_Click">
                                            <StackPanel Margin="8" HorizontalAlignment="Center">
                                                <TextBlock Text="CAM" Foreground="#4A8FC0" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                                <TextBlock Text="From image" Foreground="{DynamicResource Brush.Text.Primary}" FontSize="{DynamicResource Musait.Font.Section}" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                                <TextBlock Text="Capture or attach a reference photo" Foreground="{DynamicResource Brush.Text.Tertiary}" FontSize="{DynamicResource Musait.Font.Description}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="FamilyFromJsonButton"
                                                Grid.Column="2"
                                                MinHeight="86"
                                                Style="{DynamicResource ComposerPresetCardStyle}"
                                                ToolTip="Paste or browse a Family JSON definition"
                                                Click="FamilyFromJsonButton_Click">
                                            <StackPanel Margin="8" HorizontalAlignment="Center">
                                                <TextBlock Text="{}{ }" Foreground="#9B8FE8" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                                <TextBlock Text="From JSON" Foreground="{DynamicResource Brush.Text.Primary}" FontSize="{DynamicResource Musait.Font.Section}" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                                <TextBlock Text="Paste or browse a schema directly" Foreground="{DynamicResource Brush.Text.Tertiary}" FontSize="{DynamicResource Musait.Font.Description}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                    <Button Content="Attach image or .json file"
                                            Style="{DynamicResource MusaitSecondaryButtonStyle}"
                                            MinHeight="42"
                                            Margin="0,10,0,0"
                                            Click="FamilyAttachAnyButton_Click"/>
                                </StackPanel>

                                <StackPanel x:Name="FamilyImageView" Visibility="Collapsed">
                                    <DockPanel Margin="0,0,0,10">
                                        <Button Content="&lt;" Style="{DynamicResource MusaitIconButtonStyle}" Width="24" Height="24" DockPanel.Dock="Left" Click="FamilyBackToSourceButton_Click"/>
                                        <TextBlock Text="Family - image to JSON" Foreground="{DynamicResource Brush.Text.Primary}" FontSize="{DynamicResource Musait.Font.Section}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </DockPanel>
                                    <Border x:Name="FamilyReferenceDropZone"
                                            Background="{DynamicResource Brush.Background.Secondary}"
                                            BorderBrush="{DynamicResource Brush.Border.Secondary}"
                                            BorderThickness="1"
                                            CornerRadius="{DynamicResource Musait.Radius.Panel}"
                                            MinHeight="126"
                                            Padding="0"
                                            Margin="0,0,0,10"
                                            Cursor="Hand"
                                            AllowDrop="True"
                                            MouseLeftButtonUp="FamilyReferenceDropZone_MouseLeftButtonUp"
                                            DragOver="FamilyReferenceDropZone_DragOver"
                                            Drop="FamilyReferenceDropZone_Drop">
                                        <Grid>
                                            <Image x:Name="FamilyReferenceImage"
