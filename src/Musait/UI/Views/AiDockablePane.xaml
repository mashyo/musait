                                        <TextBlock Text="From JSON" Foreground="{DynamicResource Brush.Text.Primary}" FontSize="{DynamicResource Musait.Font.Section}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </DockPanel>
                                    <TextBox x:Name="FamilyJsonTextBox"
                                             Style="{DynamicResource MusaitTextBoxStyle}"
                                             MinHeight="126"
                                             MaxHeight="180"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             FontFamily="Consolas"
                                             FontSize="10"
                                             Text="{}{ &quot;schema&quot;: &quot;musait.family.rfa.v2&quot;,&#x0a;  &quot;name&quot;: &quot;Simple_Block&quot;,&#x0a;  &quot;category&quot;: &quot;Furniture&quot;,&#x0a;  &quot;host&quot;: &quot;non-hosted&quot;,&#x0a;  &quot;units&quot;: &quot;mm&quot;,&#x0a;  &quot;capability&quot;: &quot;static&quot;,&#x0a;  &quot;archetype&quot;: &quot;&quot;,&#x0a;  &quot;reference_planes&quot;: [&#x0a;    {&quot;name&quot;:&quot;Left&quot;,&quot;direction&quot;:&quot;x&quot;,&quot;offset&quot;:0,&quot;is_reference&quot;:&quot;Strong&quot;},&#x0a;    {&quot;name&quot;:&quot;Right&quot;,&quot;direction&quot;:&quot;x&quot;,&quot;offset&quot;:&quot;Width&quot;,&quot;is_reference&quot;:&quot;Strong&quot;},&#x0a;    {&quot;name&quot;:&quot;Front&quot;,&quot;direction&quot;:&quot;y&quot;,&quot;offset&quot;:0,&quot;is_reference&quot;:&quot;Strong&quot;},&#x0a;    {&quot;name&quot;:&quot;Back&quot;,&quot;direction&quot;:&quot;y&quot;,&quot;offset&quot;:&quot;Depth&quot;,&quot;is_reference&quot;:&quot;Strong&quot;},&#x0a;    {&quot;name&quot;:&quot;Bottom&quot;,&quot;direction&quot;:&quot;z&quot;,&quot;offset&quot;:0,&quot;is_reference&quot;:&quot;Strong&quot;},&#x0a;    {&quot;name&quot;:&quot;Top&quot;,&quot;direction&quot;:&quot;z&quot;,&quot;offset&quot;:&quot;Height&quot;,&quot;is_reference&quot;:&quot;Strong&quot;}&#x0a;  ],&#x0a;  &quot;parameters&quot;: [&#x0a;    {&quot;name&quot;:&quot;Width&quot;,&quot;type&quot;:&quot;length&quot;,&quot;instance_or_type&quot;:&quot;type&quot;,&quot;default_value&quot;:600,&quot;group&quot;:&quot;Dimensions&quot;},&#x0a;    {&quot;name&quot;:&quot;Depth&quot;,&quot;type&quot;:&quot;length&quot;,&quot;instance_or_type&quot;:&quot;type&quot;,&quot;default_value&quot;:400,&quot;group&quot;:&quot;Dimensions&quot;},&#x0a;    {&quot;name&quot;:&quot;Height&quot;,&quot;type&quot;:&quot;length&quot;,&quot;instance_or_type&quot;:&quot;type&quot;,&quot;default_value&quot;:300,&quot;group&quot;:&quot;Dimensions&quot;}&#x0a;  ],&#x0a;  &quot;geometry&quot;: [&#x0a;    {&quot;id&quot;:&quot;body&quot;,&quot;kind&quot;:&quot;extrusion&quot;,&quot;solid_or_void&quot;:&quot;solid&quot;,&quot;subcategory&quot;:&quot;Body&quot;,&quot;material&quot;:&quot;Default Material&quot;,&quot;bounds&quot;:{&quot;x0&quot;:&quot;Left&quot;,&quot;x1&quot;:&quot;Right&quot;,&quot;y0&quot;:&quot;Front&quot;,&quot;y1&quot;:&quot;Back&quot;,&quot;z0&quot;:&quot;Bottom&quot;,&quot;z1&quot;:&quot;Top&quot;}}&#x0a;  ],&#x0a;  &quot;constraints&quot;: [],&#x0a;  &quot;materials&quot;: [{&quot;name&quot;:&quot;Default Material&quot;,&quot;appearance&quot;:&quot;neutral&quot;}],&#x0a;  &quot;subcategories&quot;: [&quot;Body&quot;],&#x0a;  &quot;features&quot;: {},&#x0a;  &quot;diagnostics&quot;: [],&#x0a;  &quot;_todo&quot;: []&#x0a;}"/>
                                    <Grid Margin="0,8,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="7"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="FamilyAttachJsonButton"
                                                Grid.Column="0"
                                                Content="Browse .json"
                                                Style="{DynamicResource MusaitSecondaryButtonStyle}"
                                                ToolTip="Choose an existing Family JSON file"
                                                Click="FamilyAttachJsonButton_Click"/>
                                        <Button x:Name="FamilyPasteJsonButton"
                                                Grid.Column="2"
                                                Content="Paste"
                                                Style="{DynamicResource MusaitSecondaryButtonStyle}"
                                                ToolTip="Save Family JSON text from the clipboard"
                                                Click="FamilyPasteJsonButton_Click"/>
                                    </Grid>
                                    <Border x:Name="FamilyJsonValidationCard"
                                            Background="{DynamicResource Brush.Background.Secondary}"
                                            BorderBrush="{DynamicResource Brush.Border.Secondary}"
                                            BorderThickness="1"
                                            CornerRadius="{DynamicResource Musait.Radius.Panel}"
                                            Padding="8"
                                            Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock x:Name="FamilyPipelineStatusText"
                                                       Text="Paste or browse a Family JSON definition."
                                                       Foreground="{DynamicResource Brush.Text.Secondary}"
                                                       FontSize="{DynamicResource Musait.Font.Body}"
                                                       TextWrapping="Wrap"
                                                       LineHeight="17"/>
                                            <TextBlock x:Name="FamilyPipelineJsonPathText"
                                                       Text="No JSON attached"
                                                       Foreground="{DynamicResource Brush.Text.Tertiary}"
                                                       FontSize="{DynamicResource Musait.Font.Description}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,6,0,0"/>
                                            <TextBlock x:Name="FamilyPipelinePreviewText"
                                                       Text=""
                                                       Foreground="{DynamicResource Brush.Text.Tertiary}"
                                                       FontSize="{DynamicResource Musait.Font.Description}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Button x:Name="FamilyUseInlineJsonButton"
                                            Content="Use this JSON -> Preview"
                                            Style="{DynamicResource MusaitPrimaryButtonStyle}"
                                            Height="32"
                                            Click="FamilyUseInlineJsonButton_Click"/>
                                </StackPanel>

                                <StackPanel x:Name="FamilyAcquireView" Visibility="Collapsed">
                                    <DockPanel Margin="0,0,0,10">
                                        <Button Content="&lt;" Style="{DynamicResource MusaitIconButtonStyle}" Width="24" Height="24" DockPanel.Dock="Left" Click="FamilyBackToImageButton_Click"/>
                                        <TextBlock Text="AI Studio - Acquiring JSON" Foreground="{DynamicResource Brush.Text.Primary}" FontSize="{DynamicResource Musait.Font.Section}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </DockPanel>
                                    <Border Background="#104CAF82"
                                            BorderBrush="#304CAF82"
                                            BorderThickness="1"
                                            CornerRadius="{DynamicResource Musait.Radius.Panel}"
                                            Padding="8,6"
                                            Margin="0,0,0,9">
                                        <DockPanel LastChildFill="True">
                                            <Border Width="18"
                                                    Height="18"
                                                    CornerRadius="9"
                                                    Background="#1A4CAF82"
                                                    BorderBrush="{DynamicResource Brush.State.Ready}"
                                                    BorderThickness="1.5"
                                                    DockPanel.Dock="Left"
                                                    Margin="0,0,7,0">
                                                <TextBlock Text="OK" Foreground="{DynamicResource Brush.State.Ready}" FontSize="7" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="auto via URL param"
                                                       DockPanel.Dock="Right"
                                                       Foreground="{DynamicResource Brush.Text.Tertiary}"
                                                       FontSize="9"
                                                       VerticalAlignment="Center"
                                                       Margin="7,0,0,0"/>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="Gemini 3.5 Flash" Foreground="{DynamicResource Brush.State.Ready}" FontSize="{DynamicResource Musait.Font.Body}" FontWeight="SemiBold"/>
                                                <Border Background="#1F4CAF82" BorderBrush="#604CAF82" BorderThickness="1" CornerRadius="3" Padding="4,1" Margin="5,0,0,0">
                                                    <TextBlock Text="Free" Foreground="{DynamicResource Brush.State.Ready}" FontSize="8.5" FontWeight="SemiBold"/>
                                                </Border>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                    <StackPanel Margin="0,0,0,8">
                                        <Border Style="{DynamicResource FamilyAcquireStepCardStyle}">
                                            <DockPanel>
                                                <Border Width="18" Height="18" CornerRadius="9" Background="#1A4CAF82" BorderBrush="{DynamicResource Brush.State.Ready}" BorderThickness="1.5" DockPanel.Dock="Left" Margin="0,0,7,0">
                                                    <TextBlock Text="OK" Foreground="{DynamicResource Brush.State.Ready}" FontSize="7" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource Brush.Text.Tertiary}" FontSize="{DynamicResource Musait.Font.Description}" LineHeight="15">
                                                    <Run Text="Image and prompt sent" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text.Primary}"/>
                                                    <Run Text=" - AI Studio has your Family reference."/>
                                                </TextBlock>
                                            </DockPanel>
                                        </Border>
                                        <Border Style="{DynamicResource FamilyAcquireStepCardStyle}">
                                            <DockPanel>
                                                <Border Width="18" Height="18" CornerRadius="9" Background="#14C89A3C" BorderBrush="{DynamicResource Brush.State.Warning}" BorderThickness="1.5" DockPanel.Dock="Left" Margin="0,0,7,0">
                                                    <TextBlock Text="2" Foreground="{DynamicResource Brush.State.Warning}" FontSize="8" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource Brush.Text.Tertiary}" FontSize="{DynamicResource Musait.Font.Description}" LineHeight="15">
                                                    <Run Text="Answer questions" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text.Primary}"/>
                                                    <Run Text=" in AI Studio until one complete JSON object appears."/>
                                                </TextBlock>
                                            </DockPanel>
                                        </Border>
                                        <Border Style="{DynamicResource FamilyAcquireStepCardStyle}" Margin="0">
                                            <DockPanel>
                                                <Border Width="18" Height="18" CornerRadius="9" Background="{DynamicResource Brush.Background.Primary}" BorderBrush="{DynamicResource Brush.Border.Tertiary}" BorderThickness="1.5" DockPanel.Dock="Left" Margin="0,0,7,0">
                                                    <TextBlock Text="3" Foreground="{DynamicResource Brush.Text.Tertiary}" FontSize="8" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource Brush.Text.Tertiary}" FontSize="{DynamicResource Musait.Font.Description}" LineHeight="15">
                                                    <Run Text="Acquire latest" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text.Primary}"/>
                                                    <Run Text=" to validate and move into Preview."/>
                                                </TextBlock>
                                            </DockPanel>
                                        </Border>
                                    </StackPanel>
                                    <DockPanel Margin="0,0,0,9">
                                        <Ellipse x:Name="FamilyAcquireReadinessDot" Width="6" Height="6" Fill="{DynamicResource Brush.Border.Tertiary}" DockPanel.Dock="Left" Margin="1,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="FamilyAcquireReadinessText"
                                                   Text="Waiting for complete Family JSON in AI Studio"
                                                   Foreground="{DynamicResource Brush.Text.Tertiary}"
                                                   FontSize="9"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
