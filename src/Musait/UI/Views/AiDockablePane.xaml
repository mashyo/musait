<UserControl x:Class="Musait.UI.Views.AiDockablePane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="350"
             Background="{DynamicResource Brush.Background.Primary}"
             Foreground="{DynamicResource Brush.Text.Primary}"
             FontFamily="Segoe UI">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Musait;component/UI/Themes/MusaitTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="ComposerTabButtonStyle" TargetType="Button">
                <Setter Property="Height" Value="26"/>
                <Setter Property="MinWidth" Value="0"/>
                <Setter Property="Padding" Value="4,0"/>
                <Setter Property="Background" Value="{DynamicResource Brush.Background.Secondary}"/>
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Tertiary}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Secondary}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontSize" Value="{DynamicResource Musait.Font.Description}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="ButtonBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{DynamicResource Musait.Radius.Control}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource Brush.Text.Tertiary}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.45"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ComposerPresetCardStyle" TargetType="Button">
                <Setter Property="MinHeight" Value="54"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Background" Value="{DynamicResource Brush.Background.Secondary}"/>
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Secondary}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="CardBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{DynamicResource Musait.Radius.Panel}">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource Brush.Background.Tertiary}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.45"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ServiceTabButtonStyle" TargetType="Button">
                <Setter Property="Height" Value="28"/>
                <Setter Property="Padding" Value="2,0"/>
                <Setter Property="Background" Value="{DynamicResource Brush.Transparent}"/>
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Tertiary}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Transparent}"/>
                <Setter Property="BorderThickness" Value="0,0,0,2"/>
                <Setter Property="FontSize" Value="9"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="ButtonBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource Brush.Background.Secondary}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.45"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="SegmentButtonStyle" TargetType="Button">
                <Setter Property="Height" Value="26"/>
                <Setter Property="MinWidth" Value="42"/>
                <Setter Property="Padding" Value="8,0"/>
                <Setter Property="Background" Value="{DynamicResource Brush.Background.Tertiary}"/>
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Tertiary}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Tertiary}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontSize" Value="{DynamicResource Musait.Font.Description}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="ButtonBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource Brush.Background.Canvas}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.45"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="FamilyFooterStepButtonStyle" TargetType="Button">
                <Setter Property="MinWidth" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Background" Value="{DynamicResource Brush.Transparent}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Transparent}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="ButtonBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.78"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="FamilyAcquireStepCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource Brush.Background.Secondary}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Secondary}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="{DynamicResource Musait.Radius.Panel}"/>
                <Setter Property="Padding" Value="7,6"/>
                <Setter Property="Margin" Value="0,0,0,5"/>
            </Style>

            <Style x:Key="FamilyAcquirePrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource MusaitPrimaryButtonStyle}">
                <Setter Property="Height" Value="31"/>
                <Setter Property="MinWidth" Value="0"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="Background" Value="{DynamicResource Brush.Background.Primary}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Tertiary}"/>
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
            </Style>

            <Style x:Key="FamilyAcquireSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource MusaitSecondaryButtonStyle}">
                <Setter Property="Height" Value="31"/>
                <Setter Property="MinWidth" Value="0"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="Background" Value="{DynamicResource Brush.Background.Primary}"/>
            </Style>

            <Style x:Key="MusaitCaptureButtonStyle" TargetType="Button">
                <Setter Property="Height" Value="26"/>
                <Setter Property="Padding" Value="11,0"/>
                <Setter Property="Background" Value="{DynamicResource Brush.Accent.Primary}"/>
                <Setter Property="Foreground" Value="{DynamicResource Brush.Accent.PrimaryText}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Transparent}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="{DynamicResource Musait.Font.Section}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="ButtonBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{DynamicResource Musait.Radius.Control}"
                                    TextElement.Foreground="{TemplateBinding Foreground}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"
                                                  TextElement.Foreground="{TemplateBinding Foreground}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.78"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource Brush.Text.Secondary}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.45"/>
                                    <Setter Property="Cursor" Value="Arrow"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ComposerGradientCardStyle" TargetType="Button">
                <Setter Property="Width" Value="52"/>
                <Setter Property="Height" Value="44"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="0,0,5,0"/>
                <Setter Property="Foreground" Value="#D9FFFFFF"/>
                <Setter Property="BorderBrush" Value="#20FFFFFF"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="CardBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{DynamicResource Musait.Radius.Panel}"
                                    ClipToBounds="True"
                                    TextElement.Foreground="{TemplateBinding Foreground}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  TextElement.Foreground="{TemplateBinding Foreground}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="#70FFFFFF"/>
                                    <Setter TargetName="CardBorder" Property="Opacity" Value="0.96"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="CardBorder" Property="Opacity" Value="0.84"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.45"/>
                                    <Setter Property="Cursor" Value="Arrow"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ComposerArrowButtonStyle" TargetType="Button" BasedOn="{StaticResource MusaitIconButtonStyle}">
                <Setter Property="Width" Value="17"/>
                <Setter Property="Height" Value="38"/>
                <Setter Property="Foreground" Value="{DynamicResource Brush.Border.Tertiary}"/>
                <Setter Property="FontSize" Value="{DynamicResource Musait.Font.Section}"/>
            </Style>

            <Style x:Key="ComposerAccordionButtonStyle" TargetType="Button">
                <Setter Property="MinHeight" Value="30"/>
                <Setter Property="Padding" Value="8,5"/>
                <Setter Property="Background" Value="{DynamicResource Brush.Background.Secondary}"/>
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Tertiary}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Secondary}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontSize" Value="{DynamicResource Musait.Font.Description}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="ButtonBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{DynamicResource Musait.Radius.Control}"
                                    TextElement.Foreground="{TemplateBinding Foreground}">
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Center"
                                                  TextElement.Foreground="{TemplateBinding Foreground}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource Brush.Background.Tertiary}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="PromptModifierChipStyle" TargetType="{x:Type primitives:ToggleButton}">
                <Setter Property="Height" Value="20"/>
                <Setter Property="MinWidth" Value="0"/>
                <Setter Property="Padding" Value="7,0"/>
                <Setter Property="Margin" Value="0,0,4,4"/>
                <Setter Property="Background" Value="{DynamicResource Brush.Background.Tertiary}"/>
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Tertiary}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Tertiary}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontSize" Value="{DynamicResource Musait.Font.Description}"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type primitives:ToggleButton}">
                            <Border x:Name="ChipBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{DynamicResource Musait.Radius.Control}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ChipBorder" Property="BorderBrush" Value="{DynamicResource Brush.Text.Tertiary}"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="ChipBorder" Property="BorderThickness" Value="2"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.45"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{DynamicResource Brush.Background.Primary}">
        <Grid.RowDefinitions>
            <RowDefinition Height="34"/>
            <RowDefinition Height="28"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource Brush.Background.Secondary}"
                BorderBrush="{DynamicResource Brush.Border.Secondary}"
                BorderThickness="0,0,0,1"
                Padding="9,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="StatusChip"
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Background="{DynamicResource Brush.Background.Tertiary}"
                        BorderBrush="{DynamicResource Brush.Border.Tertiary}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="7,2"
                        Margin="0,0,5,0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="StatusDot"
                                 Width="6"
                                 Height="6"
                                 Fill="{DynamicResource Brush.State.Capturing}"
                                 VerticalAlignment="Center"
                                 Margin="0,0,5,0"/>
                        <TextBlock x:Name="StatusText"
                                   Text="Loading Gemini"
                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                   FontSize="{DynamicResource Musait.Font.Description}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>

                <Button x:Name="AboutButton"
                        Grid.Column="2"
                        Style="{DynamicResource MusaitIconButtonStyle}"
                        ToolTip="About"
                        AutomationProperties.Name="About"
                        Click="AboutBtn_Click">
                    <TextBlock Text="i"
                               Foreground="{DynamicResource Brush.State.InfoText}"
                               FontSize="13"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="8"
                                              ShadowDepth="0"
                                              Color="#7CC9F0"
                                              Opacity="0.38"/>
                        </TextBlock.Effect>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMouseOver, ElementName=AboutButton}" Value="True">
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="10"
                                                                  ShadowDepth="0"
                                                                  Color="#A7DFFF"
                                                                  Opacity="0.5"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsKeyboardFocused, ElementName=AboutButton}" Value="True">
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="10"
                                                                  ShadowDepth="0"
                                                                  Color="#A7DFFF"
                                                                  Opacity="0.55"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>

                <Button x:Name="SnipButton"
                        Grid.Column="3"
                        Style="{DynamicResource MusaitIconButtonStyle}"
                        ToolTip="Snip region"
                        AutomationProperties.Name="Snip region"
                        Click="SnipBtn_Click">
                    <Path Data="M6 2 V6 H2 M18 22 V18 H22 M6 2 V16 C6 17.1 6.9 18 8 18 H22 M2 6 H16 C17.1 6 18 6.9 18 8 V22"
                          Stroke="{DynamicResource Brush.Text.Tertiary}"
                          StrokeThickness="1.7"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Fill="{DynamicResource Brush.Transparent}"
                          Width="16"
                          Height="16"
                          Stretch="Uniform"/>
                </Button>

                <Button x:Name="SettingsButton"
                        Grid.Column="4"
                        Style="{DynamicResource MusaitIconButtonStyle}"
                        ToolTip="Settings"
                        AutomationProperties.Name="Settings"
                        Click="SettingsBtn_Click">
                    <Path Data="M12 15A3 3 0 1 0 12 9A3 3 0 0 0 12 15Z M19.4 15A1.65 1.65 0 0 0 19.73 16.82L19.79 16.88A2 2 0 1 1 16.96 19.71L16.9 19.65A1.65 1.65 0 0 0 15.08 19.32A1.65 1.65 0 0 0 14.08 20.83V21A2 2 0 0 1 10.08 21V20.91A1.65 1.65 0 0 0 9.08 19.4A1.65 1.65 0 0 0 7.26 19.73L7.2 19.79A2 2 0 1 1 4.37 16.96L4.43 16.9A1.65 1.65 0 0 0 4.76 15.08A1.65 1.65 0 0 0 3.25 14.08H3A2 2 0 0 1 3 10.08H3.09A1.65 1.65 0 0 0 4.6 9.08A1.65 1.65 0 0 0 4.27 7.26L4.21 7.2A2 2 0 1 1 7.04 4.37L7.1 4.43A1.65 1.65 0 0 0 8.92 4.76H9A1.65 1.65 0 0 0 10 3.25V3A2 2 0 0 1 14 3V3.09A1.65 1.65 0 0 0 15 4.6A1.65 1.65 0 0 0 16.82 4.27L16.88 4.21A2 2 0 1 1 19.71 7.04L19.65 7.1A1.65 1.65 0 0 0 19.32 8.92V9A1.65 1.65 0 0 0 20.83 10H21A2 2 0 0 1 21 14H20.91A1.65 1.65 0 0 0 19.4 15Z"
                          Stroke="{DynamicResource Brush.Text.Tertiary}"
                          StrokeThickness="1.2"
                          Fill="{DynamicResource Brush.Transparent}"
                          Width="16"
                          Height="16"
                          Stretch="Uniform"/>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="{DynamicResource Brush.Background.Canvas}"
                BorderBrush="{DynamicResource Brush.Border.Primary}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="RendersTabButton"
                        Grid.Column="0"
                        Style="{DynamicResource ServiceTabButtonStyle}"
                        Tag="Renders"
                        Click="ServiceTabButton_Click"
                        ToolTip="Gemini renders">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Path Data="M12 2 L13.6 8.4 L20 10 L13.6 11.6 L12 18 L10.4 11.6 L4 10 L10.4 8.4 Z"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Width="11"
                              Height="11"
                              Stretch="Uniform"
                              Margin="0,0,4,0"/>
                        <TextBlock Text="RENDERS"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BuildTabButton"
                        Grid.Column="1"
                        Style="{DynamicResource ServiceTabButtonStyle}"
                        Tag="Build"
                        Click="ServiceTabButton_Click"
                        ToolTip="Build tools">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Path Data="M2 12 C5 6 9 4 12 4 C15 4 19 6 22 12 C19 18 15 20 12 20 C9 20 5 18 2 12 Z M12 15 A3 3 0 1 0 12 9 A3 3 0 0 0 12 15 Z"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.8"
                              Fill="{DynamicResource Brush.Transparent}"
                              Width="12"
                               Height="12"
                               Stretch="Uniform"
                               Margin="0,0,4,0"/>
                        <TextBlock Text="BUILD"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                x:Name="ActionRowBorder"
                Height="38"
                Background="{DynamicResource Brush.Background.Primary}"
                BorderBrush="{DynamicResource Brush.Border.Primary}"
                BorderThickness="0,0,0,1"
                Padding="9,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>



                <Button x:Name="CaptureButton"
                        Style="{DynamicResource MusaitCaptureButtonStyle}"
                        ToolTip="Capture viewport"
                        AutomationProperties.Name="Capture viewport"
                        Click="CaptureBtn_Click"
                        Margin="0,0,7,0">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M4 7H7L8.4 5H15.6L17 7H20V18H4Z M12 16A3 3 0 1 0 12 10A3 3 0 0 0 12 16Z"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.4"
                              Fill="{DynamicResource Brush.Transparent}"
                              Width="14"
                              Height="14"
                              Stretch="Uniform"
                              Margin="0,0,5,0"/>
                        <TextBlock Text="Capture"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                   FontSize="{DynamicResource Musait.Font.Section}"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>

                <Border x:Name="RenderModeSegment"
                           Grid.Column="1"
                          Background="{DynamicResource Brush.Background.Tertiary}"
                          BorderBrush="{DynamicResource Brush.Border.Tertiary}"
                          BorderThickness="1"
                          CornerRadius="{DynamicResource Musait.Radius.Control}"
                          Margin="0,0,0,0"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Center"
                          Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="RendersVizModeButton"
                                Tag="Visualize"
                                Style="{DynamicResource SegmentButtonStyle}"
                                Click="RendersModeButton_Click"
                                ToolTip="Visualize mode">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="*" Margin="0,0,3,0"/>
                                <TextBlock Text="Visualize"/>
                            </StackPanel>
                        </Button>
