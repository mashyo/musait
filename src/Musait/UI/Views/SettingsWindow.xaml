<Window x:Class="Musait.UI.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Musait Settings" Height="420" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource Brush.Background.Primary}"
        Foreground="{DynamicResource Brush.Text.Primary}"
        FontSize="13">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Musait;component/UI/Themes/MusaitTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0,4,0,4"/>
            </Style>
            <Style TargetType="CheckBox">
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
                <Setter Property="Margin" Value="0,6,0,6"/>
            </Style>
            <Style TargetType="ComboBox">
                <Setter Property="Background" Value="{DynamicResource Brush.Background.Secondary}"/>
                <Setter Property="Foreground" Value="{DynamicResource Brush.Accent.PrimaryText}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Secondary}"/>
                <Setter Property="Padding" Value="6,4"/>
                <Setter Property="Margin" Value="0,4,0,4"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Settings" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15"/>

        <!-- Options -->
        <StackPanel Grid.Row="1">
            <!-- Captures Configuration -->
            <TextBlock Text="Viewport Capture Resolution:" FontWeight="Medium" Margin="0,0,0,2"/>
            <ComboBox ItemsSource="{Binding Resolutions}" SelectedIndex="{Binding ResolutionIndex}"/>

            <CheckBox Content="Fill capture canvas with white background" IsChecked="{Binding ForceWhiteBackground}"/>
            <CheckBox Content="Use shaded display style during capture" IsChecked="{Binding ChangeDisplayMode}"/>
            <CheckBox Content="Save capture archives to Pictures folder" IsChecked="{Binding AutoArchiveCaptures}"/>
            <CheckBox Content="Auto-send captures without review" IsChecked="{Binding AutoSendCaptures}"
                      ToolTip="Expert mode. When off, Musait shows a review composer before sending."/>
            <CheckBox Content="Show Trends tab in Composer" IsChecked="{Binding ShowTrendsInComposer}"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Save Settings" Click="SaveBtn_Click" Width="100" Height="30" Margin="0,0,10,0" Background="{DynamicResource Brush.Accent.Primary}" Foreground="{DynamicResource Brush.Accent.PrimaryText}" BorderThickness="0" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Cancel" Click="CancelBtn_Click" Width="80" Height="30" Background="{DynamicResource Brush.Background.Tertiary}" Foreground="{DynamicResource Brush.Accent.PrimaryText}" BorderThickness="0" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>

